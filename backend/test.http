@baseUrl = http://localhost:3001/api
@jahr = 2026
@monat = 1




### ============================================================================
### MITARBEITER (Frontend DTO)
### ============================================================================

### GET alle Mitarbeiter
GET {{baseUrl}}/mitarbeiter

### GET Mitarbeiter nach mnr
@MNR = 6
GET {{baseUrl}}/mitarbeiter/{{MNR}}

### POST Mitarbeiter anlegen (Frontend-Format)
POST {{baseUrl}}/mitarbeiter
Content-Type: application/json

{
  "vorname": "Test4",
  "nachname": "Frontend",
  "arbeitsstunden": 40,
  "springer": "Ja",
  "hauptfiliale": 1,
  "nebenfilialen": [2],
  "strasse": "Testweg 1",
  "ort": "Wien",
  "postleitzahl": "1010",
  "land": "Österreich",

  "telefon1": "+43 660 111111",
  "telefon2": "",
  "email1": "test@demo.at",
  "email2": "",

  "anmerkung": "test_"
}

### PUT Mitarbeiter bearbeiten
@MNR_UPDATE = 6
PUT {{baseUrl}}/mitarbeiter/{{MNR_UPDATE}}
Authorization: {{token}}
Content-Type: application/json

{
  "vorname": "Test-Updated",
  "nachname": "Frontend-Updated 13",
  "arbeitsstunden": 40,
  "springer": "Ja",
  "hauptfiliale": 2,
  "nebenfilialen": [1],

  "strasse": "Updateweg 9",
  "ort": "Wien",
  "postleitzahl": "1010",
  "land": "Österreich",

  "telefon1": "+43 660 999999",
  "email1": "update@demo.at",

  "anmerkungen": "Update Test"
}

### DELETE Mitarbeiter
@MNR_DELETE = 6
DELETE {{baseUrl}}/mitarbeiter/{{MNR_DELETE}}
Authorization: {{token}}


### ============================================================================
### FILIALEN
### ============================================================================

### GET alle Filialen
GET {{baseUrl}}/filialen
Authorization: {{token}}

### GET Filiale nach fnr
@FNR = 1
GET {{baseUrl}}/filialen/{{FNR}}
Authorization: {{token}}

### POST Filiale anlegen
POST {{baseUrl}}/filialen
Authorization: {{token}}
Content-Type: application/json

{
  "filialname": "Wien",
  "farbe": "#5c18bbff",
  "ort": "Wien",
  "strasse": "Hauptplatz 1",
  "plz": "1000",
  "land": "Österreich",
  "email": "g@firma.at",
  "telefon": "+43 3332 12345",
  "algorithmid": 1
}

### PUT Filiale bearbeiten
@FNR_UPDATE = 3
PUT {{baseUrl}}/filialen/{{FNR_UPDATE}}
Authorization: {{token}}
Content-Type: application/json

{
  "filialname": "Zentrale Wien ALT",
  "farbe": "#23db69",
  "algorithmid": 1
}

### DELETE Filiale
@FNR_DELETE = 3
DELETE {{baseUrl}}/filialen/{{FNR_DELETE}}
Authorization: {{token}}


### ============================================================================
### DIENSTPLAN
### ============================================================================

### POST Dienstplan generieren
POST {{baseUrl}}/dienstplan/generate
Authorization: {{token}}
Content-Type: application/json

{
  "jahr": {{jahr}},
  "monat": {{monat}}
}

### GET Dienstplan raw
GET {{baseUrl}}/dienstplan?jahr={{jahr}}&monat={{monat}}
Authorization: {{token}}

### GET Dienstplan View
GET {{baseUrl}}/dienstplan/view?jahr={{jahr}}&monat={{monat}}
Authorization: {{token}}

### DELETE Dienstplan Monat löschen
DELETE {{baseUrl}}/dienstplan/{{jahr}}/{{monat}}
Authorization: {{token}}


### ============================================================================
### SHIFT
### ============================================================================

### POST shift ändern
@DIENST_ID = 3641
POST {{baseUrl}}/dienstplan/shift
Authorization: {{token}}
Content-Type: application/json

{
  "id": {{DIENST_ID}},
  "schicht_typ": "F"
}


### ============================================================================
### SHIFT MIT ERSATZ
### ============================================================================

@ALT_ID = 3641
@NEU_ID = 3796
POST {{baseUrl}}/dienstplan/shiftMitErsatz
Authorization: {{token}}
Content-Type: application/json

{
  "altId": {{ALT_ID}},
  "neuId": {{NEU_ID}},
  "schicht_typ": "K"
}


### ============================================================================
### ERSATZ
### ============================================================================

@DIENST_ID = 3641
GET {{baseUrl}}/dienstplan/{{DIENST_ID}}/ersatz
Authorization: {{token}}
Accept: application/json


### ============================================================================
### STUNDEN
### ============================================================================

PUT {{baseUrl}}/dienstplan/stunden
Authorization: {{token}}
Content-Type: application/json

{
  "mnr": 14,
  "jahr": 2026,
  "monat": 1,
  "ist_stunden_monat": 166
}